{
  "name": "@ocean-industries-concept-lab/openbridge-webcomponents",
  "version": "0.0.16",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ocean-Industries-Concept-Lab/openbridge-webcomponents-jip.git",
    "directory": "packages/openbridge-webcomponents"
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "yarn run build:translations && yarn run typecheck && yarn run build:bundle && yarn run build:ts && yarn run analyze && yarn run build:wrappers",
    "build:ts": "vite build",
    "build:ts:watch": "vite build --watch",
    "build:bundle": "tsx ./script/generate-bundle-entry.ts && vite build --mode bundle",
    "build:translations": "lit localize build",
    "build:wrappers": "lit labs gen --framework=vue --framework=react --framework=angular --framework=svelte --out=.. && node fix-generated.cjs",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "storybook:server": "http-server -p 6006 storybook-static",
    "download:icons": "tsx ./script/download-icons.ts",
    "new:component": "tsx ./new-component.ts",
    "test-storybook": "vitest --project=storybook",
    "test-storybook:watch": "vitest --project=storybook --watch",
    "update-snapshots": "rm -rf __vis__/linux/__baselines__ && mv __vis__/linux/__results__/ __vis__/linux/__baselines__/",
    "translations:extract": "lit localize extract",
    "prepack": "yarn build",
    "format": "prettier \"**/*.{cjs,html,js,json,md,ts}\"  --write",
    "format:check": "prettier \"**/*.{cjs,html,js,json,md,ts}\"  --check",
    "fix-imports": "node fix-imports.mjs",
    "fix-imports:check": "node fix-imports.mjs --dry-run",
    "lint": "yarn run lint:lit-analyzer && yarn run lint:eslint",
    "lint-npm": "npm run lint:lit-analyzer && npm run lint:eslint",
    "lint:eslint": "eslint 'src/**/*.ts'",
    "lint:lit-analyzer": "lit-analyzer --strict --maxWarnings 0",
    "analyze": "cem analyze --litelement --globs \"src/**/*.ts\" --exclude \"src/**/*.stories.ts\"",
    "analyze:watch": "cem analyze --litelement --globs \"src/**/*.ts\" --exclude \"src/**/*.stories.ts\" --watch",
    "test:browser": "vitest --config=vitest.browser.config.ts"
  },
  "dependencies": {
    "@lit-labs/observers": "^2.0.5",
    "@lit/localize": "^0.12.2",
    "chart.js": "^4.5.0",
    "lit": "^3.3.1",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.10.4",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.30.0",
    "@lit-labs/cli": "file:lit-labs-cli-0.6.5.tgz",
    "@lit-labs/cli-localize": "^0.2.1",
    "@lit-labs/gen-wrapper-angular": "file:lit-labs-gen-wrapper-angular-0.1.4.tgz",
    "@lit-labs/gen-wrapper-react": "^0.3.3",
    "@lit-labs/gen-wrapper-svelte": "file:lit-labs-gen-wrapper-svelte-0.0.1.tgz",
    "@lit-labs/gen-wrapper-vue": "file:lit-labs-gen-wrapper-vue-0.4.1.tgz",
    "@open-wc/lit-helpers": "^0.7.0",
    "@playwright/test": "^1.57.0",
    "@storybook/addon-docs": "^10.1.4",
    "@storybook/addon-links": "^10.1.4",
    "@storybook/addon-themes": "^10.1.4",
    "@storybook/addon-vitest": "^10.1.4",
    "@storybook/web-components-vite": "^10.1.4",
    "@topcli/prompts": "^2.2.0",
    "@types/jest-image-snapshot": "^6",
    "@types/node": "^24.0.3",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@vitest/browser-playwright": "^4.0.15",
    "@vitest/coverage-v8": "^4.0.15",
    "dotenv": "^16.6.1",
    "eslint": "^9.29.0",
    "eslint-plugin-file-extension-in-import-ts": "^2.1.1",
    "eslint-plugin-storybook": "^10.1.4",
    "figma-api": "^1.12.0",
    "glob": "^13.0.0",
    "globals": "^16.2.0",
    "globby": "^14.1.0",
    "http-server": "^14.1.1",
    "jest-image-snapshot": "^6.5.1",
    "lit-analyzer": "^2.0.3",
    "nodemon": "^3.1.10",
    "openai": "^5.8.2",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.0",
    "postcss-mixins": "^11.0.3",
    "postcss-nesting": "^13.0.2",
    "prettier": "^3.5.3",
    "rollup-plugin-postcss-lit": "^2.2.0",
    "storybook": "^10.1.4",
    "storybook-addon-tag-badges": "^3.0.2",
    "storybook-addon-vis": "3.0.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.43.0",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-full-reload": "^1.2.0",
    "vitest": "^4.0.15",
    "vitest-browser-lit": "^1.0.1",
    "vitest-plugin-vis": "file:vitest-plugin-vis-4.1.0.tgz"
  },
  "types": "./dist/index.d.ts",
  "customElements": "custom-elements.json",
  "overrides": {
    "storybook": "$storybook"
  }
}
