{
  "name": "@oicl/openbridge-webcomponents",
  "version": "0.0.16",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ocean-Industries-Concept-Lab/openbridge-webcomponents-jip.git",
    "directory": "packages/openbridge-webcomponents"
  },
  "homepage": "https://www.openbridge.no",
  "license": "Apache-2.0",
  "scripts": {
    "👷_BUILD_____________________________________________________": "echo _____",
    "build": "npm run build:translations && npm run build:ts",
    "build:full": "npm run build:translations && npm run typecheck && npm run build:bundle && npm run build:ts && npm run analyze && npm run wrappers",
    "build:ts": "vite build",
    "build:ts:watch": "vite build --watch",
    "build:bundle": "tsx ./script/generate-bundle-entry.ts && vite build --mode bundle",
    "build:translations": "lit localize build",
    "prepack": "npm run build && npm run build:bundle && npm run analyze",
    "📚_STORYBOOK_________________________________________________": "echo _____",
    "storybook": "npm run analyze && storybook dev -p 6006 --no-open",
    "test-storybook": "vitest --project=storybook",
    "test-storybook:watch": "vitest --project=storybook --watch",
    "update-snapshots": "rm -rf __vis__/linux/__baselines__ && mv __vis__/linux/__results__/ __vis__/linux/__baselines__/",
    "build-storybook": "storybook build",
    "storybook:server": "http-server -p 6006 storybook-static",
    "preview": "vite preview",
    "prebuild-storybook": "npm run build:translations",
    "🧩_COMPONENT_________________________________________________": "echo _____",
    "new:component": "tsx ./new-component.ts",
    "🧪_CHECKS____________________________________________________": "echo _____",
    "typecheck": "tsc --noEmit",
    "format": "prettier \"**/*.{cjs,html,js,json,md,ts,css}\"  --write",
    "format:check": "prettier \"**/*.{cjs,html,js,json,md,ts,css}\"  --check",
    "lint": "npm run lint:lit-analyzer && npm run lint:eslint",
    "lint:eslint": "eslint 'src/**/*.ts'",
    "lint:lit-analyzer": "lit-analyzer --strict --maxWarnings 0",
    "fix-imports": "node fix-imports.mjs",
    "fix-imports:check": "node fix-imports.mjs --dry-run",
    "test:browser": "vitest --config=vitest.browser.config.ts",
    "📦_WRAPPERS__________________________________________________": "echo _____",
    "wrappers": "npm run wrappers:clean && npm run wrappers:generate && npm run wrappers:post-fix",
    "wrappers:clean": "git clean -fdx -e README.md ../openbridge-webcomponents-*",
    "wrappers:generate": "lit labs gen --framework=vue --framework=react --framework=angular --framework=svelte --out=..",
    "wrappers:post-fix": "node fix-generated.cjs",
    "📜_SCRIPTS___________________________________________________": "echo _____",
    "download:icons": "tsx ./script/download-icons.ts",
    "analyze": "cem analyze --litelement --globs \"src/**/*.ts\" --exclude \"src/**/*.stories.ts\"",
    "analyze:watch": "cem analyze --litelement --globs \"src/**/*.ts\" --exclude \"src/**/*.stories.ts\" --watch",
    "言_TRANSLATIONS______________________________________________": "echo _____",
    "translations:extract": "lit localize extract"
  },
  "dependencies": {
    "@lit-labs/observers": "^2.1.0",
    "@lit/localize": "^0.12.2",
    "chart.js": "^4.5.1",
    "lit": "^3.3.2",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@jackolope/ts-lit-plugin": "^3.1.6",
    "@lit-labs/cli": "file:lit-labs-cli-0.6.5.tgz",
    "@lit-labs/cli-localize": "^0.2.2",
    "@lit-labs/gen-wrapper-angular": "file:lit-labs-gen-wrapper-angular-0.1.4.tgz",
    "@lit-labs/gen-wrapper-react": "^0.3.5",
    "@lit-labs/gen-wrapper-svelte": "file:lit-labs-gen-wrapper-svelte-cf2df9d.tgz",
    "@lit-labs/gen-wrapper-vue": "file:lit-labs-gen-wrapper-vue-0.4.1.tgz",
    "@open-wc/lit-helpers": "^0.7.0",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-docs": "^10.2.17",
    "@storybook/addon-links": "^10.2.17",
    "@storybook/addon-themes": "^10.2.19",
    "@storybook/addon-vitest": "^10.2.17",
    "@storybook/web-components-vite": "^10.2.17",
    "@topcli/prompts": "^2.4.1",
    "@types/jest-image-snapshot": "^6",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.3",
    "eslint-plugin-storybook": "^10.2.17",
    "figma-api": "^2.1.2-beta",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "globby": "^16.1.1",
    "gsap": "^3.14.2",
    "http-server": "^14.1.1",
    "jest-image-snapshot": "^6.5.2",
    "lit-analyzer": "^2.0.3",
    "nodemon": "^3.1.14",
    "openai": "^6.27.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "postcss-mixins": "^12.1.2",
    "postcss-nesting": "^14.0.0",
    "prettier": "^3.8.1",
    "rollup-plugin-postcss-lit": "^2.2.0",
    "storybook": "^10.2.17",
    "storybook-addon-tag-badges": "^3.0.6",
    "storybook-addon-vis": "3.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-full-reload": "^1.2.0",
    "vitest": "^4.0.18",
    "vitest-browser-lit": "^1.0.1",
    "vitest-plugin-vis": "file:vitest-plugin-vis-4.1.0.tgz"
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "files": [
    "./dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "customElements": "custom-elements.json",
  "overrides": {
    "storybook": "$storybook"
  }
}
