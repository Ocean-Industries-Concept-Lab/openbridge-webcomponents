{
  "name": "@ocean-industries-concept-lab/openbridge-webcomponents",
  "version": "0.0.16",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ocean-Industries-Concept-Lab/openbridge-webcomponents-jip.git",
    "directory": "packages/openbridge-webcomponents"
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "yarn run build:translations && yarn run typecheck && yarn run build:ts && yarn run analyze && yarn run build:wrappers",
    "build:ts": "vite build",
    "build:ts:watch": "vite build --watch",
    "build:translations": "lit localize build",
    "build:wrappers": "lit labs gen --framework=vue --framework=react --framework=angular --out=.. && node fix-generated.cjs",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "storybook:server": "http-server -p 6006 storybook-static",
    "download:icons": "tsx ./script/download-icons.ts",
    "new:component": "tsx ./new-component.ts",
    "test-storybook": "test-storybook",
    "test-storybook:watch": "test-storybook --watch",
    "test-storybook:in-docker": "docker run --rm -v $PWD/__snapshots__/:/app/packages/openbridge-webcomponents/__snapshots__ -v $PWD/src/:/app/packages/openbridge-webcomponents/src --rm openbridge-webcomponents-storybook",
    "test-storybook:in-docker:win": "docker run --rm -v %cd%\\__snapshots__\\:/app/packages/openbridge-webcomponents/__snapshots__ -v %cd%\\src\\:/app/packages/openbridge-webcomponents/src openbridge-webcomponents-storybook",
    "test-storybook:in-docker:watch": "docker run --rm -it -v $PWD/__snapshots__/:/app/packages/openbridge-webcomponents/__snapshots__ -v $PWD/src/:/app/packages/openbridge-webcomponents/src openbridge-webcomponents-storybook /bin/sh -c \"npm run test-storybook -- --url http://host.docker.internal:6006 --watchAll --verbose\"",
    "test-storybook:in-docker:update-snapshots": "docker run --rm -v $PWD/__snapshots__/:/app/packages/openbridge-webcomponents/__snapshots__ -v $PWD/src/:/app/packages/openbridge-webcomponents/src --rm openbridge-webcomponents-storybook /bin/sh -c \"npm run test-storybook -- --url http://host.docker.internal:6006 -u\"",
    "test-storybook:in-docker:update-snapshots:win": "docker run --rm -v %cd%\\__snapshots__\\:/app/packages/openbridge-webcomponents/__snapshots__ -v %cd%\\src\\:/app/packages/openbridge-webcomponents/src openbridge-webcomponents-storybook /bin/sh -c \"npm run test-storybook -- --url http://host.docker.internal:6006 -u\"",
    "prepack": "yarn build",
    "format": "prettier \"**/*.{cjs,html,js,json,md,ts}\"  --write",
    "format:check": "prettier \"**/*.{cjs,html,js,json,md,ts}\"  --check",
    "fix-imports": "node fix-imports.mjs",
    "fix-imports:check": "node fix-imports.mjs --dry-run",
    "lint": "yarn run lint:lit-analyzer && yarn run lint:eslint",
    "lint-npm": "npm run lint:lit-analyzer && npm run lint:eslint",
    "lint:eslint": "eslint 'src/**/*.ts'",
    "lint:lit-analyzer": "lit-analyzer --strict --maxWarnings 0",
    "analyze": "cem analyze --litelement --globs \"src/**/*.ts\" --exclude \"src/**/*.stories.ts\"",
    "analyze:watch": "cem analyze --litelement --globs \"src/**/*.ts\" --exclude \"src/**/*.stories.ts\" --watch"
  },
  "dependencies": {
    "@lit-labs/observers": "^2.0.5",
    "@lit/localize": "^0.12.2",
    "lit": "^3.3.0",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.10.4",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.30.0",
    "@lit-labs/cli": "file:./lit-labs-cli-0.6.5.tgz",
    "@lit-labs/cli-localize": "^0.2.1",
    "@lit-labs/gen-wrapper-angular": "file:lit-labs-gen-wrapper-angular-0.1.4.tgz",
    "@lit-labs/gen-wrapper-react": "^0.3.3",
    "@lit-labs/gen-wrapper-vue": "file:lit-labs-gen-wrapper-vue-0.4.1.tgz",
    "@open-wc/lit-helpers": "^0.7.0",
    "@playwright/test": "^1.53.1",
    "@storybook/addon-docs": "^9.0.11",
    "@storybook/addon-links": "^9.0.11",
    "@storybook/addon-themes": "^9.0.11",
    "@storybook/test-runner": "^0.23.0",
    "@storybook/web-components-vite": "^9.0.11",
    "@topcli/prompts": "^2.2.0",
    "@types/jest-image-snapshot": "^6",
    "@types/node": "^24.0.3",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "dotenv": "^17.0.1",
    "eslint": "^9.29.0",
    "eslint-plugin-file-extension-in-import-ts": "^2.1.1",
    "eslint-plugin-storybook": "^9.0.11",
    "figma-api": "^1.12.0",
    "globals": "^16.2.0",
    "globby": "^14.1.0",
    "http-server": "^14.1.1",
    "jest-image-snapshot": "^6.5.1",
    "lit-analyzer": "^2.0.3",
    "nodemon": "^3.1.10",
    "openai": "^5.8.2",
    "playwright": "^1.53.0",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.0",
    "postcss-mixins": "^11.0.3",
    "postcss-nesting": "^13.0.2",
    "prettier": "^3.5.3",
    "rollup-plugin-postcss-lit": "^2.2.0",
    "storybook": "^9.0.11",
    "storybook-addon-tag-badges": "^2.0.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-full-reload": "^1.2.0"
  },
  "types": "./dist/index.d.ts",
  "customElements": "custom-elements.json",
  "overrides": {
    "storybook": "$storybook"
  }
}
